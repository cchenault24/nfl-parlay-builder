{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "lib",
        "baseUrl": "."
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/middleware/**",
        "src/service/ai/providers/**",
        "src/service/ai/BaseParlayProvider.ts",
        "src/service/ai/ContextBuilder.ts",
        "src/service/ai/PromptEngine.ts",
        "src/service/ai/ParlayAIService.ts",
        "src/util/zodSchemas.ts"
    ]
}