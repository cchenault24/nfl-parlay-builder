{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS", 
        "moduleResolution": "node",
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "rootDir": "src",
        "outDir": "lib",
        "baseUrl": "."
    },
    "include": [
        "src/**/*"
    ]
}
